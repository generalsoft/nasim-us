---
import { getLocaleFromUrl, otherLocale, localizedHref } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

const currentLocale = getLocaleFromUrl(Astro.url) as Locale;
const switchLocale = otherLocale(currentLocale);
// Build the path for the other locale — strip the current locale prefix first,
// then prepend the new one.
let pathWithoutLocale = Astro.url.pathname;
if (currentLocale !== 'en') {
  pathWithoutLocale = Astro.url.pathname.replace('/' + currentLocale, '') || '/';
}
const switchHref = localizedHref(switchLocale, pathWithoutLocale);
---

<a class="lang-switch" href={switchHref} hreflang={switchLocale} lang={switchLocale}>
  {switchLocale === 'ar' ? 'العربية' : 'English'}
</a>

<style>
  .lang-switch {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--gray-300);
    border-radius: 0.375rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--gray-200);
    text-decoration: none;
    transition: all var(--theme-transition);
  }

  .lang-switch:hover,
  .lang-switch:focus-visible {
    border-color: var(--accent-regular);
    color: var(--accent-regular);
    background: var(--accent-subtle-overlay);
  }
</style>
