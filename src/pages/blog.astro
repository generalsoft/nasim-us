---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';
import ImageCarousel from '../components/ImageCarousel.astro';

const posts = (await getCollection('blog'))
	.filter((p) => (p.data.lang ?? 'en') === 'en')
	.sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const postImages = posts.map((p) => ({
  src: p.data.img,
  href: `/blog/${p.slug}`,
}));

const carouselArticles = posts.map((p) => ({
  title: p.data.title,
  description: p.data.description,
  href: `/blog/${p.slug}`,
  tags: p.data.tags ?? [],
}));
---

<BaseLayout title="Blog | Abid Nasim" description="Read Nasim's latest blog posts">
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Blog"
				tagline="Thoughts, experiments, and practical write-ups on AI and engineering."
				align="start"
			/>
			<div id="carousel-articles-data" data-articles={JSON.stringify(carouselArticles)} hidden></div>
		<ImageCarousel images={postImages} alt="Blog post preview" />
			<Grid variant="offset">
				{
					posts.map((post) => (
						<li>
							<PortfolioPreview project={post} basePath="/blog" />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
