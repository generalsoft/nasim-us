---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';
import ImageCarousel from '../components/ImageCarousel.astro';

const hobbies = (await getCollection('hobby'))
	.filter((h) => (h.data.lang ?? 'en') === 'en')
	.sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const hobbyImages = hobbies.map((h) => ({
  src: h.data.img,
  href: `/hobby/${h.slug}`,
}));

const carouselArticles = hobbies.map((h) => ({
  title: h.data.title,
  description: h.data.description,
  href: `/hobby/${h.slug}`,
  tags: h.data.tags ?? [],
}));
---

<BaseLayout title="Hobby | Abid Nasim" description="Personal hobby projects and tinkering">
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Hobby"
				tagline="Side projects and experiments built for curiosity and fun."
				align="start"
			/>
			<div id="carousel-articles-data" data-articles={JSON.stringify(carouselArticles)} hidden></div>
		<ImageCarousel images={hobbyImages} alt="Hobby project preview" />
			<Grid variant="offset">
				{
					hobbies.map((item) => (
						<li>
							<PortfolioPreview project={item} basePath="/hobby" />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
