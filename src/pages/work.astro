---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';
import ImageCarousel from '../components/ImageCarousel.astro';

const projects = (await getCollection('work'))
	.filter((p) => (p.data.lang ?? 'en') === 'en')
	.sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const projectImages = projects.map((p) => ({
  src: p.data.img,
  href: `/work/${p.slug}`,
}));

const carouselArticles = projects.map((p) => ({
  title: p.data.title,
  description: p.data.description,
  href: `/work/${p.slug}`,
  tags: p.data.tags ?? [],
}));
---

<BaseLayout
	title="My Work | Abid Nasim"
	description="Learn about Nasim's most recent projects"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="My Work"
				tagline="See my most recent projects below to get an idea of my past experience."
				align="start"
			/>
			<div id="carousel-articles-data" data-articles={JSON.stringify(carouselArticles)} hidden></div>
		<ImageCarousel images={projectImages} alt="Project preview" />
			<Grid variant="offset">
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project} />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
