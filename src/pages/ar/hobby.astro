---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import PortfolioPreview from '../../components/PortfolioPreview.astro';
import Hero from '../../components/Hero.astro';
import Grid from '../../components/Grid.astro';
import ImageCarousel from '../../components/ImageCarousel.astro';
import { t } from '../../i18n/utils';

const locale = 'ar';

const hobbies = (await getCollection('hobby'))
	.filter((h) => (h.data.lang ?? 'en') === locale)
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const hobbyImages = hobbies.map((h) => ({
  src: h.data.img,
  href: `/ar/hobby/${h.slug}`,
}));

const carouselArticles = hobbies.map((h) => ({
  title: h.data.title,
  description: h.data.description,
  href: `/ar/hobby/${h.slug}`,
  tags: h.data.tags ?? [],
}));
---

<BaseLayout title={t(locale, 'hobby.title')} description={t(locale, 'hobby.desc')}>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title={t(locale, 'hobby.heading')}
				tagline={t(locale, 'hobby.tagline')}
				align="start"
			/>
			<div id="carousel-articles-data" data-articles={JSON.stringify(carouselArticles)} hidden></div>
		<ImageCarousel images={hobbyImages} alt="معاينة هواية" />
			<Grid variant="offset">
				{
					hobbies.map((hobby) => (
						<li>
							<PortfolioPreview project={hobby} basePath="/ar/hobby" />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
