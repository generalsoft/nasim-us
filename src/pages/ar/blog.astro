---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import PortfolioPreview from '../../components/PortfolioPreview.astro';
import Hero from '../../components/Hero.astro';
import Grid from '../../components/Grid.astro';
import ImageCarousel from '../../components/ImageCarousel.astro';
import { t } from '../../i18n/utils';

const locale = 'ar';

const posts = (await getCollection('blog'))
	.filter((p) => (p.data.lang ?? 'en') === locale)
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const postImages = posts.map((p) => ({
  src: p.data.img,
  href: `/ar/blog/${p.slug}`,
}));

const carouselArticles = posts.map((p) => ({
  title: p.data.title,
  description: p.data.description,
  href: `/ar/blog/${p.slug}`,
  tags: p.data.tags ?? [],
}));
---

<BaseLayout title={t(locale, 'blog.title')} description={t(locale, 'blog.desc')}>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title={t(locale, 'blog.heading')}
				tagline={t(locale, 'blog.tagline')}
				align="start"
			/>
			<div id="carousel-articles-data" data-articles={JSON.stringify(carouselArticles)} hidden></div>
		<ImageCarousel images={postImages} alt="معاينة مقال" readMoreLabel={t(locale, 'carousel.readmore')} />
			<Grid variant="offset">
				{
					posts.map((post) => (
						<li>
							<PortfolioPreview project={post} basePath="/ar/blog" />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
