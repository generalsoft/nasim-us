---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';

import CallToAction from '../../components/CallToAction.astro';
import Grid from '../../components/Grid.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';
import PortfolioPreview from '../../components/PortfolioPreview.astro';

import ContactCTA from '../../components/ContactCTA.astro';
import Skills from '../../components/Skills.astro';
import { t } from '../../i18n/utils';

const locale = 'ar';

const projects = (await getCollection('work'))
	.filter((p) => (p.data.lang ?? 'en') === locale)
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

---

<BaseLayout title={t(locale, 'home.title')}>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title={t(locale, 'home.hero')}
					tagline={t(locale, 'home.tagline')}
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="code" size="1.33em" /> {t(locale, 'home.roles.dev')}</Pill>
						<Pill><Icon icon="pencil-line" size="1.33em" /> {t(locale, 'home.roles.writer')}</Pill>
						<Pill><Icon icon="trophy" size="1.33em" /> {t(locale, 'home.roles.mentor')}</Pill>
					</div>
				</Hero>

				<img
					alt="Abid smiling in black suit"
					width="480"
					height="620"
					src="/assets/abid.jpg"
				/>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>{t(locale, 'home.selectedWork')}</h3>
					<p>{t(locale, 'home.workDesc')}</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/ar/work/">
						{t(locale, 'home.viewAll')}
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>
